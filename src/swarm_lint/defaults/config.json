{
  "enabled": {
    "max-file-lines": true,
    "max-folder-items": true,
    "no-nested-imports": true,
    "vulture": true,
    "eslint": true,
    "knip": true,
    "endpoints": true,
    "classes": true
  },

  "rules": {
    "max-file-lines": 250,
    "max-folder-items": 7,
    "vulture-min-confidence": 1,
    "vulture-error-threshold": 1,
    "no-nested-imports": true,
    "endpoint-ignore-routes": []
  },

  "include_extensions": [".py", ".ts", ".tsx", ".js", ".jsx"],

  "exclude": [
    "node_modules",
    ".venv",
    "dist",
    "build",
    "__pycache__",
    ".git",
    ".cursor",
    ".vscode",
    "swarm-lint-config"
  ],

  "exceptions": {
    "max-file-lines": [],
    "max-folder-items": [],
    "no-nested-imports": [],
    "vulture": [],
    "endpoints": [],
    "classes": []
  },

  "vulture": {
    "targets": ["."],
    "venv_path": null,
    "exclude": ".venv,__pycache__",
    "whitelist": null,
    "ignore_decorators": "@*.router.*,@*.websocket,@pytest.fixture,@pytest.fixture*",
    "ignore_names": "cls"
  },

  "eslint": {
    "directory": ".",
    "args": ["src/", "--format", "json", "--no-warn-ignored"]
  },

  "knip": {
    "directory": "."
  },

  "endpoints": {
    "backend_dir": "backend",
    "frontend_src_dir": "frontend/src"
  },

  "classes": {
    "directory": "backend"
  }
}
